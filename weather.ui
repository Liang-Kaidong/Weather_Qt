     <property name="styleSheet">
      <string notr="true">QProgressBar#day2TemperatureProgressBar {
    border-radius: 5px;
    border: 1px solid #ffffff;
    background-color: transparent;
    qproperty-textVisible: false; /* 隐藏进度文字，取消注释即可 */
}

/* 进度填充部分（关键：单独设置圆角，否则填充部分是直角） */
QProgressBar#day2TemperatureProgressBar::chunk {
    border-radius: 3px; /* 比整体圆角小2px，避免填充部分超出边框圆角 */
    background-color: #2a9919;
    /* 可选：渐变背景 */
