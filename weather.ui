    <widget class="QProgressBar" name="day4TemperatureProgressBar">
     <property name="geometry">
      <rect>
       <x>357</x>
       <y>137</y>
       <width>71</width>
       <height>10</height>
      </rect>
     </property>
     <property name="styleSheet">
      <string notr="true">QProgressBar#day4TemperatureProgressBar {
    /* 1. 进度条整体圆角（核心） */
    border-radius: 5px; /* 整体圆角半径，推荐6-10px */
    
    /* 2. 边框设置（可选，带颜色边框） */
    border: 1px solid #ffffff; /* 1px浅灰色边框 */
    
    /* 3. 背景透明（延续你的需求） */
    background-color: transparent;
    
    /* 5. 文本样式（可选，隐藏/显示进度文字） */
    color: #666666; /* 进度文字颜色 */
    text-align: center; /* 文字居中 */
    qproperty-textVisible: false; /* 隐藏进度文字，取消注释即可 */
}

/* 进度填充部分（关键：单独设置圆角，否则填充部分是直角） */
QProgressBar#day4TemperatureProgressBar::chunk {
    border-radius: 3px; /* 比整体圆角小2px，避免填充部分超出边框圆角 */
    background-color: #2a9919; /* 进度条填充颜色（蓝色，可自定义） */
    /* 可选：渐变背景 */
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #2a9919, stop:1 #4cff38);
}</string>
     </property>
     <property name="minimum">
