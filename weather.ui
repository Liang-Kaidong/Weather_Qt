    <widget class="QProgressBar" name="todayTemperatureProgressBar">
     <property name="geometry">
      <rect>
       <x>357</x>
       <y>53</y>
       <width>71</width>
       <height>10</height>
      </rect>
     </property>
     <property name="styleSheet">
      <string notr="true">QProgressBar#todayTemperatureProgressBar {
    border-radius: 5px;
    border: 1px solid #ffffff;
    background-color: transparent;
    qproperty-textVisible: false; /* 隐藏进度文字，取消注释即可 */
}

/* 进度填充部分*/
QProgressBar#todayTemperatureProgressBar::chunk {
    border-radius: 3px; /* 比整体圆角小2px，避免填充部分超出边框圆角 */
    background-color: #2a9919;
    /* 渐变背景 */
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #2a9919, stop:1 #4cff38);
}</string>
     </property>
     <property name="minimum">
      <number>-55</number>
     </property>
     <property name="maximum">
      <number>75</number>
     </property>
     <property name="value">
      <number>35</number>
     </property>
     <property name="textVisible">
      <bool>false</bool>
     </property>
     <property name="orientation">
      <enum>Qt::Horizontal</enum>
     </property>
     <property name="textDirection">
      <enum>QProgressBar::TopToBottom</enum>
     </property>
    </widget>
